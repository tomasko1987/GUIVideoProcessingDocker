{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5250"
      }
    }
  },
  "Camera": {
    "Urls": [
      "http://<CAMERA_IP>:<PORT>/stream"
    ],
    "ConnectTimeoutSec": 15,
    "FrameTimeoutSec": 5,
    "ReconnectBackoffMaxSec": 60,
    "LedIntensity": 14,
    "CamFramesize": 13,
    "CamBrightness": 2,
    "CamContrast": 2,
    "CamSaturation": 2
  },
  "InfluxDB": {
    "Enabled": true,
    "Url": "http://<INFLUXDB_IP>:<PORT>",
    "Token": "<YOUR_INFLUXDB_TOKEN>",
    "Org": "<YOUR_ORG>",
    "Bucket": "<YOUR_BUCKET>",
    "ReconnectDelaySeconds": 10
  },
  "Pipeline": {
    "ROIX": 52,
    "ROIY": 23,
    "ROIWidth": 13,
    "ROIHeight": 19,
    "BilateralD": 5,
    "BilateralSigmaColor": 40,
    "BilateralSigmaSpace": 40,
    "CLAHEClipLimit": 5.0,
    "CLAHETileGridSizeX": 2,
    "CLAHETileGridSizeY": 2,
    "AdaptiveThresholdBlockSize": 101,
    "AdaptiveThresholdC": 5,
    "MorphologyKernelSize": 3,
    "MorphologyOpenIterations": 1,
    "MorphologyCloseIterations": 1,
    "MinArea": 80,
    "FromLeft": 49,
    "FromRight": 49,
    "NumEvalIntervalSeconds": 1,
    "OnnxModelPath": "model/model.onnx",
    "OnnxMinConfidence": 0.89,
    "StoreSample": true,
    "RecognitionAlgorithm": "ONNX",
    "SegmentOnThreshold": 0.35,
    "SourceTag": "T3"
  }
}
